{
  "name": "gisbuddy",
  "version": "0.1.0",
  "description": "AI-powered GIS data processing assistant",
  "author": "GISBuddy",
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:behaviors": "node scripts/check-behaviors.js behaviors.md --warn",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "fast-xml-parser": "^5.9.0",
    "openai": "^4.0.0",
    "shapefile": "^0.6.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "sharp": "^0.35.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.gisbuddy.app",
    "productName": "GISBuddy",
    "directories": {
      "output": "release"
    },
    "icon": "build/icon-duck.icns",
    "files": [
      "dist/**/*",
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "gdal-bin/",
        "to": "gdal-bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/icon-duck.png",
        "to": "icon-duck.png"
      },
      {
        "from": "build/",
        "to": "./",
        "filter": [
          "tray-icon*.png"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    }
  }
}
