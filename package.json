{
  "name": "gisbuddy",
  "version": "1.0.0",
  "description": "AI-powered GIS data processing assistant",
  "author": "GISBuddy",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "tsc && tsc -p electron/tsconfig.preload.json && node -e \"require('fs').renameSync('dist/electron/preload.js','dist/electron/preload.cjs')\" && node scripts/build-renderer.mjs",
    "build:icon": "node scripts/build-icon.mjs",
    "build:icon:win": "node scripts/build-icon-win.mjs",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:behaviors": "node scripts/check-behaviors.js behaviors.md --warn",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration/",
    "test:e2e": "npm run build && npx playwright test",
    "test:all": "npm test && npm run test:e2e",
    "prepare": "husky"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.74.2",
    "@earendil-works/pi-ai": "^0.74.2",
    "@earendil-works/pi-coding-agent": "^0.74.2",
    "@earendil-works/pi-web-ui": "^0.74.2",
    "fast-xml-parser": "^5.9.0",
    "leaflet": "^1.9.4",
    "shapefile": "^0.6.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^24.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "sharp": "^0.35.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.gisbuddy.app",
    "productName": "GISBuddy",
    "directories": {
      "output": "release"
    },
    "icon": "build/icon-duck.icns",
    "files": [
      "dist/**/*",
      "src/index.html",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "gdal-bin/",
        "to": "gdal-bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/icon-duck.png",
        "to": "icon-duck.png"
      },
      {
        "from": "build/busybox64.exe",
        "to": "busybox64.exe",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon-duck.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    }
  }
}
